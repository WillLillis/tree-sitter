let c = inherit("../c_native/grammar.tsg")

let PREC = {
    PAREN_DECLARATOR: -10, ASSIGNMENT: -2, CONDITIONAL: -1, DEFAULT: 0,
    LOGICAL_OR: 1, LOGICAL_AND: 2, INCLUSIVE_OR: 3, EXCLUSIVE_OR: 4,
    BITWISE_AND: 5, EQUAL: 6, RELATIONAL: 7, OFFSETOF: 8, SHIFT: 9,
    ADD: 10, MULTIPLY: 11, CAST: 12, SIZEOF: 13, UNARY: 14,
    CALL: 15, FIELD: 16, SUBSCRIPT: 17,
    LAMBDA: 18, NEW: 16, STRUCTURED_BINDING: -1, THREE_WAY: 8,
}

fn comma_sep1(item: rule) -> rule { seq(item, repeat(seq(",", item))) }
fn comma_sep(item: rule) -> rule { optional(comma_sep1(item)) }

// Digits with optional ' separators: e.g. digits("[0-9]") = /[0-9]('?[0-9]+)*/
fn digits(pat: rule) -> rule { seq(repeat1(pat), repeat(seq("'", repeat1(pat)))) }

let BIN_DIGIT = regexp("[01]")
let DEC_DIGIT = regexp("[0-9]")
let HEX_DIGIT = regexp("[0-9a-fA-F]")
let OCT_DIGIT = regexp("[0-7]")
let SIGN = regexp(r"[-\+]")

let ASSIGNMENT_OPERATORS: list<str> = [
    "=", "*=", "/=", "%=", "+=", "-=",
    "<<=", ">>=", "&=", "^=", "|=",
    "and_eq", "or_eq", "xor_eq",
]

let FOLD_OPERATORS: list<str> = [
    "+", "-", "*", "/", "%", "^", "&", "|",
    "=", "<", ">", "<<", ">>",
    "+=", "-=", "*=", "/=", "%=", "^=", "&=", "|=",
    ">>=", "<<=", "==", "!=", "<=", ">=",
    "&&", "||", ",", ".*", "->*",
    "or", "and", "bitor", "xor", "bitand", "not_eq",
]

grammar {
    language: "cpp",
    inherits: c,

    externals: [raw_string_delimiter, raw_string_content],

    conflicts: [
        // C
        [type_specifier, _declarator],
        [type_specifier, expression],
        [sized_type_specifier],
        [attributed_statement],
        [_declaration_modifiers, attributed_statement],
        [_declaration_modifiers, using_declaration],
        [_declaration_modifiers, attributed_statement, using_declaration],
        [_top_level_item, _top_level_statement],
        [_block_item, statement],
        [type_qualifier, extension_expression],
        // C++
        [template_function, template_type],
        [template_function, template_type, expression],
        [template_function, template_type, qualified_identifier],
        [template_function, template_type, qualified_identifier, qualified_type_identifier],
        [template_type, qualified_type_identifier],
        [qualified_type_identifier, qualified_identifier],
        [comma_expression, initializer_list],
        [expression, _declarator],
        [expression, structured_binding_declarator],
        [expression, _declarator, type_specifier],
        [expression, identifier_parameter_pack_expansion],
        [expression, _lambda_capture_identifier],
        [expression, _lambda_capture],
        [expression, structured_binding_declarator, _lambda_capture_identifier],
        [structured_binding_declarator, _lambda_capture_identifier],
        [parameter_list, argument_list],
        [type_specifier, call_expression],
        [_declaration_specifiers, _constructor_specifiers],
        [_binary_fold_operator, _fold_operator],
        [_function_declarator_seq],
        [type_specifier, sized_type_specifier],
        [initializer_pair, comma_expression],
        [expression_statement, _for_statement_body],
        [init_statement, _for_statement_body],
        [field_expression, template_method, template_type],
        [field_expression, template_method],
        [qualified_field_identifier, template_method, template_type],
        [type_specifier, template_type, template_function, expression],
        [splice_type_specifier, splice_expression],
    ],

    inline: [
        _type_identifier, _field_identifier, _statement_identifier,
        _non_case_statement, _assignment_left_expression, _expression_not_binary,
        _namespace_identifier,
    ],

    precedences: [
        [argument_list, type_qualifier],
        [_expression_not_binary, _class_name],
    ],
}

// ---------------------------------------------------------------------------
// Override rules
// ---------------------------------------------------------------------------

// _top_level_item: C version minus _old_style_function_definition, plus C++ items
override rule _top_level_item {
    choice(
        function_definition,
        linkage_specification, declaration, _top_level_statement,
        attributed_statement, type_definition, _empty_declaration,
        preproc_if, preproc_ifdef, preproc_include,
        preproc_def, preproc_function_def, preproc_call,
        namespace_definition, concept_definition, namespace_alias_definition,
        using_declaration, alias_declaration, static_assert_declaration,
        consteval_block_declaration, template_declaration, template_instantiation,
        module_declaration, export_declaration, import_declaration,
        global_module_fragment_declaration, private_module_fragment_declaration,
        alias(constructor_or_destructor_definition, function_definition),
        alias(operator_cast_definition, function_definition),
        alias(operator_cast_declaration, declaration),
    )
}

// _block_item: same as _top_level_item minus top-level-only items
override rule _block_item {
    choice(
        function_definition,
        linkage_specification, declaration, statement,
        attributed_statement, type_definition, _empty_declaration,
        preproc_if, preproc_ifdef, preproc_include,
        preproc_def, preproc_function_def, preproc_call,
        namespace_definition, concept_definition, namespace_alias_definition,
        using_declaration, alias_declaration, static_assert_declaration,
        consteval_block_declaration, template_declaration, template_instantiation,
        alias(constructor_or_destructor_definition, function_definition),
        alias(operator_cast_definition, function_definition),
        alias(operator_cast_declaration, declaration),
    )
}

override rule type_qualifier {
    choice(c::type_qualifier, "mutable", "constinit", "consteval")
}

override rule type_descriptor { prec_right(0, c::type_descriptor) }

// attribute: prepend optional `using namespace:` before C's attribute body
override rule attribute {
    seq(optional(seq("using", field(namespace, identifier), ":")),
        optional(seq(field(prefix, identifier), "::")),
        field(name, identifier), optional(argument_list))
}

override rule attribute_declaration {
    choice(c::attribute_declaration, seq("[[", comma_sep1(annotation), "]]"))
}

// function_definition: body can also be try_statement
override rule function_definition {
    seq(optional(ms_call_modifier), _declaration_specifiers,
        optional(ms_call_modifier),
        field(declarator, _declarator),
        field(body, choice(compound_statement, try_statement)))
}

override rule _declaration_modifiers {
    choice(c::_declaration_modifiers, "virtual")
}

// storage_class_specifier: remove "auto", add "thread_local"
override rule storage_class_specifier {
    choice("extern", "static", "register", "inline",
           "__inline", "__inline__", "__forceinline", "thread_local", "__thread")
}

override rule init_declarator {
    choice(
        c::init_declarator,
        seq(field(declarator, _declarator), field(value, choice(argument_list, initializer_list))),
    )
}

override rule compound_statement { prec(-1, c::compound_statement) }

override rule _field_declaration_list_item {
    choice(
        c::_field_declaration_list_item,
        template_declaration,
        alias(inline_method_definition, function_definition),
        alias(constructor_or_destructor_definition, function_definition),
        alias(constructor_or_destructor_declaration, declaration),
        alias(operator_cast_definition, function_definition),
        alias(operator_cast_declaration, declaration),
        friend_declaration,
        seq(access_specifier, ":"),
        alias_declaration, using_declaration, type_definition,
        static_assert_declaration, consteval_block_declaration,
        ";",
    )
}

override rule _declarator {
    choice(c::_declarator,
           reference_declarator, qualified_identifier, template_function,
           operator_name, destructor_name, structured_binding_declarator)
}

override rule _field_declarator {
    choice(c::_field_declarator,
           alias(reference_field_declarator, reference_declarator),
           template_method, operator_name)
}

override rule _type_declarator {
    choice(c::_type_declarator, alias(reference_type_declarator, reference_declarator))
}

override rule _abstract_declarator {
    choice(c::_abstract_declarator, abstract_reference_declarator)
}

override rule _top_level_statement {
    choice(c::_top_level_statement,
           co_return_statement, co_yield_statement, for_range_loop,
           expansion_statement, try_statement, throw_statement)
}

override rule _non_case_statement {
    choice(c::_non_case_statement,
           co_return_statement, co_yield_statement, for_range_loop,
           expansion_statement, try_statement, throw_statement)
}

override rule _for_statement_body {
    prec_dynamic(1, c::_for_statement_body)
}

override rule return_statement {
    seq(choice(c::return_statement, seq("return", initializer_list, ";")))
}

override rule _expression_not_binary {
    choice(c::_expression_not_binary,
           co_await_expression, requires_expression, requires_clause,
           template_function, qualified_identifier,
           new_expression, delete_expression, lambda_expression,
           parameter_pack_expansion, this, user_defined_literal,
           fold_expression, reflect_expression, splice_expression)
}

override rule call_expression {
    prec_dynamic(1, choice(
        c::call_expression,
        seq(field(function, choice(
            primitive_type,
            seq(optional("typename"), splice_type_specifier),
        )), field(arguments, argument_list)),
    ))
}

override rule sizeof_expression {
    prec_right(PREC.SIZEOF, choice(
        c::sizeof_expression,
        seq("sizeof", "...", "(", field(value, identifier), ")"),
    ))
}

override rule unary_expression {
    choice(
        c::unary_expression,
        prec_left(PREC.UNARY, seq(field(operator, choice("not", "compl")), field(argument, expression))),
    )
}

override rule binary_expression {
    choice(
        c::binary_expression,
        for (op: str, p: int) in [
            ("<=>", PREC.THREE_WAY),
            ("or", PREC.LOGICAL_OR), ("and", PREC.LOGICAL_AND),
            ("bitor", PREC.INCLUSIVE_OR), ("xor", PREC.EXCLUSIVE_OR),
            ("bitand", PREC.BITWISE_AND), ("not_eq", PREC.EQUAL),
        ] {
            prec_left(p, seq(field(left, expression), field(operator, op), field(right, expression)))
        }
    )
}

override rule compound_literal_expression {
    choice(
        c::compound_literal_expression,
        seq(field(type, choice(
            _class_name, primitive_type,
            seq(optional("typename"), splice_type_specifier),
        )), field(value, initializer_list)),
    )
}

override rule _assignment_left_expression {
    choice(c::_assignment_left_expression, qualified_identifier, user_defined_literal)
}

override rule parenthesized_expression {
    choice(
        c::parenthesized_expression,
        seq("(", alias(_assignment_expression_lhs, assignment_expression), ")"),
    )
}

override rule declaration {
    seq(_declaration_specifiers,
        comma_sep1(field(declarator, choice(
            seq(optional(ms_call_modifier), _declarator, optional(gnu_asm_expression)),
            init_declarator,
        ))),
        ";")
}

override rule type_specifier {
    choice(
        struct_specifier, union_specifier, enum_specifier,
        class_specifier, sized_type_specifier, primitive_type,
        template_type, dependent_type, splice_type_specifier,
        placeholder_type_specifier, decltype,
        prec_right(0, choice(
            alias(qualified_type_identifier, qualified_identifier),
            _type_identifier,
        )),
    )
}

override rule field_declaration {
    seq(_declaration_specifiers,
        comma_sep(seq(
            field(declarator, _field_declarator),
            optional(choice(
                bitfield_clause,
                field(default_value, initializer_list),
                seq("=", field(default_value, choice(expression, initializer_list))),
            )),
        )),
        optional(attribute_specifier), ";")
}

override rule switch_statement {
    seq("switch", field(condition, condition_clause), field(body, compound_statement))
}

override rule while_statement {
    seq("while", field(condition, condition_clause), field(body, statement))
}

override rule if_statement {
    prec_right(0, seq("if", optional("constexpr"),
        field(condition, condition_clause),
        field(consequence, statement),
        optional(field(alternative, else_clause))))
}

override rule subscript_expression {
    prec(PREC.SUBSCRIPT, seq(field(argument, expression), field(indices, subscript_argument_list)))
}

override rule field_expression {
    seq(
        prec(PREC.FIELD, seq(
            field(argument, expression),
            field(operator, choice(".", ".*", "->")),
        )),
        field(field, choice(
            prec_dynamic(1, _field_identifier),
            alias(qualified_field_identifier, qualified_identifier),
            destructor_name, template_method,
            alias(dependent_field_identifier, dependent_name),
            operator_name, splice_expression,
        )),
    )
}

override rule argument_list {
    seq("(", comma_sep(choice(expression, initializer_list, compound_statement)), ")")
}

// C++ number_literal uses digit separators (') and additional suffixes.
override rule number_literal {
    token(seq(
        optional(SIGN),
        choice(
            // Integer literals
            seq(choice(
                seq(choice("0b", "0B"), digits(BIN_DIGIT)),
                seq(regexp("[1-9]"), repeat(DEC_DIGIT), repeat(seq("'", repeat1(DEC_DIGIT)))),
                seq(choice("0x", "0X"), digits(HEX_DIGIT)),
                seq("0", repeat(OCT_DIGIT), repeat(seq("'", repeat1(OCT_DIGIT)))),
            ), optional(regexp(r"(ll|LL)[uU]?|[uU](ll|LL)?|[uU][lL]?|[uU][zZ]?|[lL][uU]?|[zZ][uU]?"))),
            // Float literals
            seq(choice(
                seq(digits(DEC_DIGIT), seq(regexp("[eE]"), optional(SIGN), digits(DEC_DIGIT))),
                seq(digits(DEC_DIGIT), ".", optional(digits(DEC_DIGIT)),
                    optional(seq(regexp("[eE]"), optional(SIGN), digits(DEC_DIGIT)))),
                seq(".", digits(DEC_DIGIT),
                    optional(seq(regexp("[eE]"), optional(SIGN), digits(DEC_DIGIT)))),
                seq(choice("0x", "0X"),
                    choice(digits(HEX_DIGIT),
                           seq(digits(HEX_DIGIT), ".", optional(digits(HEX_DIGIT))),
                           seq(".", digits(HEX_DIGIT))),
                    seq(regexp("[pP]"), optional(SIGN), digits(DEC_DIGIT))),
            ), optional(regexp(r"([fF](16|32|64|128)?)|[lL]|(bf16|BF16)"))),
        ),
    ))
}

override rule parameter_list {
    seq("(", comma_sep(choice(
        parameter_declaration,
        explicit_object_parameter_declaration,
        optional_parameter_declaration,
        variadic_parameter_declaration,
        "...",
    )), ")")
}

override rule assignment_expression {
    prec_right(PREC.ASSIGNMENT, seq(
        field(left, _assignment_left_expression),
        field(operator, choice(for (op: str) in ASSIGNMENT_OPERATORS { op })),
        field(right, choice(expression, initializer_list)),
    ))
}

rule annotation { seq("=", expression) }

rule _class_declaration {
    seq(repeat(choice(attribute_specifier, alignas_qualifier)),
        optional(ms_declspec_modifier),
        repeat(attribute_declaration),
        _class_declaration_item)
}

rule _class_declaration_item {
    prec_right(0, seq(
        choice(
            field(name, _class_name),
            seq(optional(field(name, _class_name)),
                optional(virtual_specifier),
                optional(base_class_clause),
                field(body, field_declaration_list)),
        ),
        optional(attribute_specifier),
    ))
}

rule class_specifier { seq("class", _class_declaration) }
override rule union_specifier { seq("union", _class_declaration) }
override rule struct_specifier { seq("struct", _class_declaration) }

rule _class_name {
    prec_right(0, choice(
        _type_identifier, template_type, splice_type_specifier,
        alias(qualified_type_identifier, qualified_identifier),
    ))
}

rule virtual_specifier { choice("final", "override") }

rule explicit_function_specifier {
    choice("explicit",
           prec(PREC.CALL, seq("explicit", "(", expression, ")")))
}

rule base_class_clause {
    seq(":", comma_sep1(seq(
        repeat(attribute_declaration),
        optional(choice(
            access_specifier,
            seq(access_specifier, optional("virtual")),
            seq("virtual", optional(access_specifier)),
        )),
        _class_name,
        optional("..."),
    )))
}

override rule enum_specifier {
    prec_right(0, seq("enum", optional(choice("class", "struct")),
        choice(
            seq(field(name, _class_name), optional(_enum_base_clause),
                optional(field(body, enumerator_list))),
            field(body, enumerator_list),
        ),
        optional(attribute_specifier)))
}

rule _enum_base_clause {
    prec_left(0, seq(":", field(base, choice(
        alias(qualified_type_identifier, qualified_identifier),
        _type_identifier, primitive_type, sized_type_specifier,
    ))))
}

rule dependent_type { prec_dynamic(-1, prec_right(0, seq("typename", type_specifier))) }

rule placeholder_type_specifier {
    prec(1, seq(
        field(constraint, optional(choice(
            alias(qualified_type_identifier, qualified_identifier),
            template_type, _type_identifier,
        ))),
        choice(auto, alias(decltype_auto, decltype)),
    ))
}

rule auto { "auto" }
rule decltype_auto { seq("decltype", "(", auto, ")") }
rule decltype { seq("decltype", "(", expression, ")") }

rule module_name { seq(identifier, repeat(seq(".", identifier))) }
rule module_partition { seq(":", module_name) }

rule module_declaration {
    seq(optional("export"), "module",
        field(name, module_name), field(partition, optional(module_partition)),
        optional(attribute_declaration), ";")
}

rule export_declaration {
    seq("export", choice(_block_item, seq("{", repeat(_block_item), "}")))
}

rule import_declaration {
    seq(optional("export"), "import",
        choice(
            field(name, module_name),
            field(partition, module_partition),
            field(header, choice(string_literal, system_lib_string)),
        ),
        optional(attribute_declaration), ";")
}

rule global_module_fragment_declaration { seq("module", ";") }
rule private_module_fragment_declaration { seq("module", ":", "private", ";") }

rule template_declaration {
    seq("template", field(parameters, template_parameter_list),
        optional(requires_clause),
        choice(
            _empty_declaration, alias_declaration, declaration,
            template_declaration, function_definition, concept_definition,
            friend_declaration,
            alias(constructor_or_destructor_declaration, declaration),
            alias(constructor_or_destructor_definition, function_definition),
            alias(operator_cast_declaration, declaration),
            alias(operator_cast_definition, function_definition),
        ))
}

rule template_instantiation {
    prec(1, seq(optional("extern"), "template",
                optional(_declaration_specifiers),
                field(declarator, _declarator), ";"))
}

rule template_parameter_list {
    seq("<", comma_sep(choice(
        parameter_declaration, optional_parameter_declaration,
        type_parameter_declaration, variadic_parameter_declaration,
        variadic_type_parameter_declaration,
        optional_type_parameter_declaration,
        template_template_parameter_declaration,
    )), alias(token(prec(1, ">")), ">"))
}

rule type_parameter_declaration { prec(1, seq(choice("typename", "class"), optional(_type_identifier))) }
rule variadic_type_parameter_declaration { prec(1, seq(choice("typename", "class"), "...", optional(_type_identifier))) }

rule optional_type_parameter_declaration {
    seq(choice("typename", "class"),
        optional(field(name, _type_identifier)),
        "=", field(default_type, type_specifier))
}

rule template_template_parameter_declaration {
    seq("template", field(parameters, template_parameter_list),
        choice(type_parameter_declaration, variadic_type_parameter_declaration,
               optional_type_parameter_declaration))
}

rule explicit_object_parameter_declaration { seq(this, parameter_declaration) }

rule optional_parameter_declaration {
    seq(_declaration_specifiers,
        field(declarator, optional(choice(_declarator, abstract_reference_declarator))),
        "=", field(default_value, expression))
}

rule variadic_parameter_declaration {
    seq(_declaration_specifiers,
        field(declarator, choice(
            variadic_declarator,
            alias(variadic_reference_declarator, reference_declarator),
        )))
}

rule variadic_declarator { seq("...", optional(identifier)) }
rule variadic_reference_declarator { seq(choice("&&", "&"), variadic_declarator) }

rule operator_cast {
    prec_right(1, seq("operator", _declaration_specifiers,
                      field(declarator, _abstract_declarator)))
}

rule field_initializer_list { seq(":", comma_sep1(field_initializer)) }

rule field_initializer {
    prec(1, seq(
        choice(_field_identifier, template_method,
               alias(qualified_field_identifier, qualified_identifier)),
        choice(initializer_list, argument_list),
        optional("..."),
    ))
}

rule inline_method_definition {
    seq(_declaration_specifiers,
        field(declarator, _field_declarator),
        choice(
            field(body, choice(compound_statement, try_statement)),
            default_method_clause, delete_method_clause, pure_virtual_clause,
        ))
}

rule _constructor_specifiers { choice(_declaration_modifiers, explicit_function_specifier) }

rule operator_cast_definition {
    seq(repeat(_constructor_specifiers),
        field(declarator, choice(operator_cast,
                                 alias(qualified_operator_cast_identifier, qualified_identifier))),
        field(body, choice(compound_statement, try_statement)))
}

rule operator_cast_declaration {
    prec(1, seq(repeat(_constructor_specifiers),
        field(declarator, choice(operator_cast,
                                 alias(qualified_operator_cast_identifier, qualified_identifier))),
        optional(seq("=", field(default_value, expression))),
        ";"))
}

rule constructor_try_statement {
    seq("try", optional(field_initializer_list),
        field(body, compound_statement), repeat1(catch_clause))
}

rule constructor_or_destructor_definition {
    seq(repeat(_constructor_specifiers),
        field(declarator, function_declarator),
        choice(
            seq(optional(field_initializer_list), field(body, compound_statement)),
            alias(constructor_try_statement, try_statement),
            default_method_clause, delete_method_clause, pure_virtual_clause,
        ))
}

rule constructor_or_destructor_declaration {
    seq(repeat(_constructor_specifiers), field(declarator, function_declarator), ";")
}

rule default_method_clause { seq("=", "default", ";") }
rule delete_method_clause { seq("=", "delete", ";") }
rule pure_virtual_clause { seq("=", regexp(r"0"), ";") }

rule friend_declaration {
    seq(optional("constexpr"), "friend",
        choice(
            declaration, function_definition,
            seq(optional(choice("class", "struct", "union")), _class_name, ";"),
        ))
}

rule access_specifier { choice("public", "private", "protected") }

rule reference_declarator { prec_dynamic(1, prec_right(0, seq(choice("&", "&&"), _declarator))) }
rule reference_field_declarator { prec_dynamic(1, prec_right(0, seq(choice("&", "&&"), _field_declarator))) }
rule reference_type_declarator { prec_dynamic(1, prec_right(0, seq(choice("&", "&&"), _type_declarator))) }
rule abstract_reference_declarator { prec_right(0, seq(choice("&", "&&"), optional(_abstract_declarator))) }

rule structured_binding_declarator {
    prec_dynamic(PREC.STRUCTURED_BINDING, seq("[", comma_sep1(identifier), "]"))
}

rule ref_qualifier { choice("&", "&&") }

rule _function_declarator_seq {
    seq(field(parameters, parameter_list),
        optional(_function_attributes_start),
        optional(ref_qualifier),
        optional(_function_exception_specification),
        optional(_function_attributes_end),
        optional(trailing_return_type),
        optional(_function_postfix))
}

rule _function_attributes_start {
    prec(1, choice(
        seq(repeat1(attribute_specifier), repeat(type_qualifier)),
        seq(repeat(attribute_specifier), repeat1(type_qualifier)),
    ))
}

rule _function_exception_specification { choice(noexcept, throw_specifier) }

rule _function_attributes_end {
    prec_right(0, seq(
        optional(gnu_asm_expression),
        choice(
            seq(repeat1(attribute_specifier), repeat(attribute_declaration)),
            seq(repeat(attribute_specifier), repeat1(attribute_declaration)),
        )))
}

rule _function_postfix {
    prec_right(0, choice(repeat1(virtual_specifier), requires_clause))
}

override rule function_declarator {
    prec_dynamic(1, seq(field(declarator, _declarator), _function_declarator_seq))
}

override rule function_field_declarator {
    prec_dynamic(1, seq(field(declarator, _field_declarator), _function_declarator_seq))
}

override rule abstract_function_declarator {
    seq(field(declarator, optional(_abstract_declarator)), _function_declarator_seq)
}

rule trailing_return_type { seq("->", type_descriptor) }

rule noexcept {
    prec_right(0, seq("noexcept", optional(seq("(", optional(expression), ")"))))
}

rule throw_specifier { seq("throw", seq("(", comma_sep(type_descriptor), ")")) }

rule template_type {
    seq(field(name, _type_identifier), field(arguments, template_argument_list))
}

rule template_method {
    seq(field(name, choice(_field_identifier, operator_name)),
        field(arguments, template_argument_list))
}

rule template_function {
    seq(field(name, identifier), field(arguments, template_argument_list))
}

rule template_argument_list {
    seq("<", comma_sep(choice(
        prec_dynamic(3, type_descriptor),
        prec_dynamic(2, alias(type_parameter_pack_expansion, parameter_pack_expansion)),
        prec_dynamic(1, expression),
    )), alias(token(prec(1, ">")), ">"))
}

rule namespace_definition {
    seq(optional("inline"), "namespace",
        optional(attribute_declaration),
        field(name, optional(choice(_namespace_identifier, nested_namespace_specifier))),
        field(body, declaration_list))
}

rule namespace_alias_definition {
    seq("namespace", field(name, _namespace_identifier), "=",
        choice(_namespace_identifier, nested_namespace_specifier, splice_specifier),
        ";")
}

rule _namespace_specifier { seq(optional("inline"), _namespace_identifier) }

rule nested_namespace_specifier {
    prec(1, seq(optional(_namespace_specifier), "::",
                choice(nested_namespace_specifier, _namespace_specifier)))
}

rule using_declaration {
    seq(repeat(attribute_declaration), "using", optional(choice("namespace", "enum")),
        choice(identifier, qualified_identifier, splice_type_specifier), ";")
}

rule alias_declaration {
    seq("using", field(name, _type_identifier), repeat(attribute_declaration),
        "=", field(type, type_descriptor), ";")
}

rule static_assert_declaration {
    seq("static_assert", "(",
        field(condition, expression),
        optional(seq(",", field(message, _string))),
        ")", ";")
}

rule consteval_block_declaration { seq("consteval", field(body, compound_statement)) }

rule concept_definition { seq("concept", field(name, identifier), "=", expression, ";") }

// Statements

rule for_range_loop {
    seq("for", "(", _for_range_loop_body, ")", field(body, statement))
}

rule _for_range_loop_body {
    seq(field(initializer, optional(init_statement)),
        _declaration_specifiers,
        field(declarator, _declarator), ":",
        field(right, choice(expression, initializer_list)))
}

rule init_statement { choice(alias_declaration, type_definition, declaration, expression_statement) }

rule condition_clause {
    seq("(", field(initializer, optional(init_statement)),
        field(value, choice(expression, comma_expression,
                            alias(condition_declaration, declaration))),
        ")")
}

rule condition_declaration {
    seq(_declaration_specifiers, field(declarator, _declarator),
        choice(
            seq("=", field(value, expression)),
            field(value, initializer_list),
        ))
}

rule co_return_statement { seq("co_return", optional(expression), ";") }
rule co_yield_statement { seq("co_yield", expression, ";") }
rule throw_statement { seq("throw", optional(expression), ";") }

rule try_statement {
    seq("try", field(body, compound_statement), repeat1(catch_clause))
}

rule catch_clause {
    seq("catch", field(parameters, parameter_list), field(body, compound_statement))
}

// Expressions

override rule _string { choice(string_literal, raw_string_literal, concatenated_string) }

rule raw_string_literal {
    seq(choice(r#"R""#, r#"LR""#, r#"uR""#, r#"UR""#, r#"u8R""#),
        choice(
            seq(field(delimiter, raw_string_delimiter), "(", raw_string_content, ")", raw_string_delimiter),
            seq("(", raw_string_content, ")"),
        ),
        "\"")
}

rule subscript_argument_list {
    seq("[", comma_sep(choice(expression, initializer_list)), "]")
}

rule co_await_expression {
    prec_left(PREC.UNARY, seq(field(operator, "co_await"), field(argument, expression)))
}

rule new_expression {
    prec_right(PREC.NEW, seq(
        optional("::"), "new",
        field(placement, optional(argument_list)),
        field(type, type_specifier),
        field(declarator, optional(new_declarator)),
        field(arguments, optional(choice(argument_list, initializer_list))),
    ))
}

rule new_declarator {
    prec_right(0, seq("[", field(length, expression), "]", optional(new_declarator)))
}

rule delete_expression { seq(optional("::"), "delete", optional(seq("[", "]")), expression) }

rule type_requirement { seq("typename", _class_name) }

rule compound_requirement {
    seq("{", expression, "}", optional("noexcept"), optional(trailing_return_type), ";")
}

rule _requirement { choice(alias(expression_statement, simple_requirement), type_requirement, compound_requirement) }
rule requirement_seq { seq("{", repeat(_requirement), "}") }

rule constraint_conjunction {
    prec_left(PREC.LOGICAL_AND, seq(
        field(left, _requirement_clause_constraint),
        field(operator, choice("&&", "and")),
        field(right, _requirement_clause_constraint)))
}

rule constraint_disjunction {
    prec_left(PREC.LOGICAL_OR, seq(
        field(left, _requirement_clause_constraint),
        field(operator, choice("||", "or")),
        field(right, _requirement_clause_constraint)))
}

rule _requirement_clause_constraint {
    choice(true, false, _class_name, fold_expression, lambda_expression, requires_expression,
           seq("(", expression, ")"),
           constraint_conjunction, constraint_disjunction)
}

rule requires_clause { seq("requires", field(constraint, _requirement_clause_constraint)) }

rule requires_parameter_list {
    seq("(", comma_sep(choice(parameter_declaration, optional_parameter_declaration, variadic_parameter_declaration)), ")")
}

rule requires_expression {
    seq("requires",
        field(parameters, optional(alias(requires_parameter_list, parameter_list))),
        field(requirements, requirement_seq))
}

rule lambda_specifier { choice("static", "constexpr", "consteval", "mutable") }

rule lambda_declarator {
    choice(
        seq(repeat(attribute_declaration), field(parameters, parameter_list),
            repeat(lambda_specifier), optional(_function_exception_specification),
            repeat(attribute_declaration), optional(trailing_return_type),
            optional(requires_clause)),
        repeat1(attribute_declaration),
        seq(repeat(attribute_declaration), trailing_return_type),
        seq(repeat(attribute_declaration), _function_exception_specification,
            repeat(attribute_declaration), optional(trailing_return_type)),
        seq(repeat(attribute_declaration), repeat1(lambda_specifier),
            optional(_function_exception_specification),
            repeat(attribute_declaration), optional(trailing_return_type)),
    )
}

rule lambda_expression {
    seq(field(captures, lambda_capture_specifier),
        optional(seq(field(template_parameters, template_parameter_list),
                     optional(field(constraint, requires_clause)))),
        optional(field(declarator, lambda_declarator)),
        field(body, compound_statement))
}

rule lambda_capture_specifier {
    prec(PREC.LAMBDA, seq("[",
        choice(
            lambda_default_capture,
            comma_sep(_lambda_capture),
            seq(lambda_default_capture, ",", comma_sep1(_lambda_capture)),
        ),
        "]"))
}

rule lambda_default_capture { choice("=", "&") }

rule _lambda_capture_identifier {
    seq(optional("&"),
        choice(identifier, qualified_identifier,
               alias(identifier_parameter_pack_expansion, parameter_pack_expansion)))
}

rule lambda_capture_initializer {
    seq(optional("&"), optional("..."),
        field(left, identifier), "=", field(right, expression))
}

rule _lambda_capture { choice(seq(optional("*"), this), _lambda_capture_identifier, lambda_capture_initializer) }

rule _fold_operator { choice(for (op: str) in FOLD_OPERATORS { op }) }

rule _binary_fold_operator {
    choice(for (op: str) in FOLD_OPERATORS { seq(field(operator, op), "...", op) })
}

rule _unary_left_fold { seq(field(left, "..."), field(operator, _fold_operator), field(right, expression)) }
rule _unary_right_fold { seq(field(left, expression), field(operator, _fold_operator), field(right, "...")) }
rule _binary_fold { seq(field(left, expression), _binary_fold_operator, field(right, expression)) }

rule fold_expression { seq("(", choice(_unary_right_fold, _unary_left_fold, _binary_fold), ")") }

rule parameter_pack_expansion { prec(-1, seq(field(pattern, expression), "...")) }
rule type_parameter_pack_expansion { seq(field(pattern, type_descriptor), "...") }
rule identifier_parameter_pack_expansion { seq(field(pattern, identifier), "...") }

rule destructor_name { prec(1, seq("~", identifier)) }

rule dependent_identifier { seq("template", template_function) }
rule dependent_field_identifier { seq("template", template_method) }
rule dependent_type_identifier { seq("template", template_type) }

rule _scope_resolution {
    prec(1, seq(
        field(scope, optional(choice(
            _namespace_identifier, template_type, decltype,
            splice_expression, splice_type_specifier,
            alias(dependent_type_identifier, dependent_name),
        ))),
        "::"))
}

rule qualified_field_identifier {
    seq(_scope_resolution,
        field(name, choice(
            alias(dependent_field_identifier, dependent_name),
            alias(qualified_field_identifier, qualified_identifier),
            template_method,
            prec_dynamic(2, _field_identifier),
        )))
}

rule qualified_identifier {
    seq(_scope_resolution,
        field(name, choice(
            alias(dependent_identifier, dependent_name),
            qualified_identifier, template_function,
            prec_dynamic(1, seq(optional("template"), identifier)),
            operator_name, destructor_name, pointer_type_declarator,
        )))
}

rule qualified_type_identifier {
    seq(_scope_resolution,
        field(name, choice(
            alias(dependent_type_identifier, dependent_name),
            alias(qualified_type_identifier, qualified_identifier),
            template_type,
            prec_dynamic(1, _type_identifier),
        )))
}

rule qualified_operator_cast_identifier {
    seq(_scope_resolution,
        field(name, choice(
            alias(qualified_operator_cast_identifier, qualified_identifier),
            operator_cast,
        )))
}

rule _assignment_expression_lhs {
    seq(field(left, expression),
        field(operator, choice(for (op: str) in ASSIGNMENT_OPERATORS { op })),
        field(right, choice(expression, initializer_list)))
}

rule reflect_expression {
    prec_right(0, seq("^^", choice("::", expression, type_descriptor)))
}

rule splice_specifier { seq("[:", expression, ":]") }
rule _splice_specialization_specifier { seq(splice_specifier, template_argument_list) }
rule splice_type_specifier { prec_right(0, choice(splice_specifier, _splice_specialization_specifier)) }
rule splice_expression { prec_right(0, choice(splice_specifier, seq("template", _splice_specialization_specifier))) }

rule expansion_statement {
    seq("template", "for", "(", _for_range_loop_body, ")", field(body, statement))
}

rule operator_name {
    prec(1, seq("operator",
        choice(
            "co_await",
            "+", "-", "*", "/", "%",
            "^", "&", "|", "~",
            "!", "=", "<", ">",
            "+=", "-=", "*=", "/=", "%=", "^=", "&=", "|=",
            "<<", ">>", ">>=", "<<=",
            "==", "!=", "<=", ">=",
            "<=>",
            "&&", "||",
            "++", "--",
            ",",
            "->*", "->",
            "()", "[]",
            "xor", "bitand", "bitor", "compl",
            "not", "xor_eq", "and_eq", "or_eq", "not_eq",
            "and", "or",
            seq(choice("new", "delete"), optional("[]")),
            seq(r#""""#, identifier),
        )))
}

rule this { "this" }

override rule concatenated_string {
    prec_right(0, seq(
        choice(identifier, string_literal, raw_string_literal),
        choice(string_literal, raw_string_literal),
        repeat(choice(identifier, string_literal, raw_string_literal)),
    ))
}

rule literal_suffix { token_immediate(regexp(r"[a-zA-Z_]\w*")) }

rule user_defined_literal {
    seq(choice(number_literal, char_literal, _string), literal_suffix)
}

rule _namespace_identifier { alias(identifier, namespace_identifier) }
