// C grammar for tree-sitter - native DSL version

grammar {
    language: "c",
    conflicts: [
        [type_specifier, _declarator],
        [type_specifier, _declarator, macro_type_specifier],
        [type_specifier, expression],
        [type_specifier, expression, macro_type_specifier],
        [type_specifier, macro_type_specifier],
        [type_specifier, sized_type_specifier],
        [sized_type_specifier],
        [attributed_statement],
        [_declaration_modifiers, attributed_statement],
        [enum_specifier],
        [type_specifier, _old_style_parameter_list],
        [parameter_list, _old_style_parameter_list],
        [function_declarator, _function_declaration_declarator],
        [_block_item, statement],
        [_top_level_item, _top_level_statement],
        [type_specifier, _top_level_expression_statement],
        [type_qualifier, extension_expression],
    ],
    extras: [regex(r"\s|\\\r?\n"), comment],
    inline: [
        _type_identifier, _field_identifier, _statement_identifier,
        _non_case_statement, _assignment_left_expression, _expression_not_binary,
    ],
    supertypes: [
        expression, statement, type_specifier,
        _declarator, _field_declarator, _type_declarator, _abstract_declarator,
    ],
    word: identifier,
}

// ---------------------------------------------------------------------------
// Constants
// ---------------------------------------------------------------------------

let PREC = {
    PAREN_DECLARATOR: -10, ASSIGNMENT: -2, CONDITIONAL: -1, DEFAULT: 0,
    LOGICAL_OR: 1, LOGICAL_AND: 2, INCLUSIVE_OR: 3, EXCLUSIVE_OR: 4,
    BITWISE_AND: 5, EQUAL: 6, RELATIONAL: 7, OFFSETOF: 8, SHIFT: 9,
    ADD: 10, MULTIPLY: 11, CAST: 12, SIZEOF: 13, UNARY: 14,
    CALL: 15, FIELD: 16, SUBSCRIPT: 17,
}

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

fn comma_sep1(item: rule) -> rule { seq(item, repeat(seq(",", item))) }
fn comma_sep(item: rule) -> rule { optional(comma_sep1(item)) }

fn preprocessor(command: str) -> rule {
    alias(regex(concat("#[ \t]*", command)), concat("#", command))
}

// ---------------------------------------------------------------------------
// Preprocessor if/ifdef/else/elif/elifdef helpers
// ---------------------------------------------------------------------------

fn preproc_if_body(content: rule, p: int, else_alt: rule, elif_alt: rule, elifdef_alt: rule) -> rule {
    prec(p, seq(preprocessor("if"), field(condition, _preproc_expression), "\n", repeat(content),
        field(alternative, optional(choice(else_alt, elif_alt, elifdef_alt))), preprocessor("endif")))
}
fn preproc_ifdef_body(content: rule, p: int, else_alt: rule, elif_alt: rule, elifdef_alt: rule) -> rule {
    prec(p, seq(choice(preprocessor("ifdef"), preprocessor("ifndef")), field(name, identifier), repeat(content),
        field(alternative, optional(choice(else_alt, elif_alt, elifdef_alt))), preprocessor("endif")))
}
fn preproc_else_body(content: rule, p: int) -> rule {
    prec(p, seq(preprocessor("else"), repeat(content)))
}
fn preproc_elif_body(content: rule, p: int, else_alt: rule, elif_alt: rule, elifdef_alt: rule) -> rule {
    prec(p, seq(preprocessor("elif"), field(condition, _preproc_expression), "\n", repeat(content),
        field(alternative, optional(choice(else_alt, elif_alt, elifdef_alt)))))
}
fn preproc_elifdef_body(content: rule, p: int, else_alt: rule, elif_alt: rule, elifdef_alt: rule) -> rule {
    prec(p, seq(choice(preprocessor("elifdef"), preprocessor("elifndef")), field(name, identifier), repeat(content),
        field(alternative, optional(choice(else_alt, elif_alt, elifdef_alt)))))
}

// ---------------------------------------------------------------------------
// Top level
// ---------------------------------------------------------------------------

rule translation_unit { repeat(_top_level_item) }

rule _top_level_item {
    choice(
        function_definition,
        alias(_old_style_function_definition, function_definition),
        linkage_specification, declaration, _top_level_statement,
        attributed_statement, type_definition, _empty_declaration,
        preproc_if, preproc_ifdef, preproc_include,
        preproc_def, preproc_function_def, preproc_call,
    )
}

rule _block_item {
    choice(
        function_definition,
        alias(_old_style_function_definition, function_definition),
        linkage_specification, declaration, statement,
        attributed_statement, type_definition, _empty_declaration,
        preproc_if, preproc_ifdef, preproc_include,
        preproc_def, preproc_function_def, preproc_call,
    )
}

// ---------------------------------------------------------------------------
// Preprocessor
// ---------------------------------------------------------------------------

rule preproc_include {
    seq(
        preprocessor("include"),
        field(path, choice(string_literal, system_lib_string, identifier,
            alias(preproc_call_expression, call_expression))),
        token.immediate(regex(r"\r?\n")),
    )
}

rule preproc_def {
    seq(preprocessor("define"), field(name, identifier),
        field(value, optional(preproc_arg)), token.immediate(regex(r"\r?\n")))
}

rule preproc_function_def {
    seq(preprocessor("define"), field(name, identifier),
        field(parameters, preproc_params),
        field(value, optional(preproc_arg)), token.immediate(regex(r"\r?\n")))
}

rule preproc_params { seq(token.immediate("("), comma_sep(choice(identifier, "...")), ")") }

rule preproc_call {
    seq(field(directive, preproc_directive),
        field(argument, optional(preproc_arg)), token.immediate(regex(r"\r?\n")))
}

// Base variants (no suffix)
rule preproc_if { preproc_if_body(_block_item, 0, preproc_else, preproc_elif, preproc_elifdef) }
rule preproc_ifdef { preproc_ifdef_body(_block_item, 0, preproc_else, preproc_elif, preproc_elifdef) }
rule preproc_else { preproc_else_body(_block_item, 0) }
rule preproc_elif { preproc_elif_body(_block_item, 0, preproc_else, preproc_elif, preproc_elifdef) }
rule preproc_elifdef { preproc_elifdef_body(_block_item, 0, preproc_else, preproc_elif, preproc_elifdef) }

// _in_field_declaration_list variants
rule preproc_if_in_field_declaration_list { preproc_if_body(_field_declaration_list_item, 0, alias(preproc_else_in_field_declaration_list, preproc_else), alias(preproc_elif_in_field_declaration_list, preproc_elif), alias(preproc_elifdef_in_field_declaration_list, preproc_elifdef)) }
rule preproc_ifdef_in_field_declaration_list { preproc_ifdef_body(_field_declaration_list_item, 0, alias(preproc_else_in_field_declaration_list, preproc_else), alias(preproc_elif_in_field_declaration_list, preproc_elif), alias(preproc_elifdef_in_field_declaration_list, preproc_elifdef)) }
rule preproc_else_in_field_declaration_list { preproc_else_body(_field_declaration_list_item, 0) }
rule preproc_elif_in_field_declaration_list { preproc_elif_body(_field_declaration_list_item, 0, alias(preproc_else_in_field_declaration_list, preproc_else), alias(preproc_elif_in_field_declaration_list, preproc_elif), alias(preproc_elifdef_in_field_declaration_list, preproc_elifdef)) }
rule preproc_elifdef_in_field_declaration_list { preproc_elifdef_body(_field_declaration_list_item, 0, alias(preproc_else_in_field_declaration_list, preproc_else), alias(preproc_elif_in_field_declaration_list, preproc_elif), alias(preproc_elifdef_in_field_declaration_list, preproc_elifdef)) }

// _in_enumerator_list variants
rule preproc_if_in_enumerator_list { preproc_if_body(seq(enumerator, ","), 0, alias(preproc_else_in_enumerator_list, preproc_else), alias(preproc_elif_in_enumerator_list, preproc_elif), alias(preproc_elifdef_in_enumerator_list, preproc_elifdef)) }
rule preproc_ifdef_in_enumerator_list { preproc_ifdef_body(seq(enumerator, ","), 0, alias(preproc_else_in_enumerator_list, preproc_else), alias(preproc_elif_in_enumerator_list, preproc_elif), alias(preproc_elifdef_in_enumerator_list, preproc_elifdef)) }
rule preproc_else_in_enumerator_list { preproc_else_body(seq(enumerator, ","), 0) }
rule preproc_elif_in_enumerator_list { preproc_elif_body(seq(enumerator, ","), 0, alias(preproc_else_in_enumerator_list, preproc_else), alias(preproc_elif_in_enumerator_list, preproc_elif), alias(preproc_elifdef_in_enumerator_list, preproc_elifdef)) }
rule preproc_elifdef_in_enumerator_list { preproc_elifdef_body(seq(enumerator, ","), 0, alias(preproc_else_in_enumerator_list, preproc_else), alias(preproc_elif_in_enumerator_list, preproc_elif), alias(preproc_elifdef_in_enumerator_list, preproc_elifdef)) }

// _in_enumerator_list_no_comma variants
rule preproc_if_in_enumerator_list_no_comma { preproc_if_body(enumerator, -1, alias(preproc_else_in_enumerator_list_no_comma, preproc_else), alias(preproc_elif_in_enumerator_list_no_comma, preproc_elif), alias(preproc_elifdef_in_enumerator_list_no_comma, preproc_elifdef)) }
rule preproc_ifdef_in_enumerator_list_no_comma { preproc_ifdef_body(enumerator, -1, alias(preproc_else_in_enumerator_list_no_comma, preproc_else), alias(preproc_elif_in_enumerator_list_no_comma, preproc_elif), alias(preproc_elifdef_in_enumerator_list_no_comma, preproc_elifdef)) }
rule preproc_else_in_enumerator_list_no_comma { preproc_else_body(enumerator, -1) }
rule preproc_elif_in_enumerator_list_no_comma { preproc_elif_body(enumerator, -1, alias(preproc_else_in_enumerator_list_no_comma, preproc_else), alias(preproc_elif_in_enumerator_list_no_comma, preproc_elif), alias(preproc_elifdef_in_enumerator_list_no_comma, preproc_elifdef)) }
rule preproc_elifdef_in_enumerator_list_no_comma { preproc_elifdef_body(enumerator, -1, alias(preproc_else_in_enumerator_list_no_comma, preproc_else), alias(preproc_elif_in_enumerator_list_no_comma, preproc_elif), alias(preproc_elifdef_in_enumerator_list_no_comma, preproc_elifdef)) }

rule preproc_arg { token(prec(-1, regex(r"\S([^/\n]|\/[^*]|\\\r?\n)*"))) }
rule preproc_directive { regex(r"#[ \t]*[a-zA-Z0-9]\w*") }

rule _preproc_expression {
    choice(
        identifier,
        alias(preproc_call_expression, call_expression),
        number_literal, char_literal, preproc_defined,
        alias(preproc_unary_expression, unary_expression),
        alias(preproc_binary_expression, binary_expression),
        alias(preproc_parenthesized_expression, parenthesized_expression),
    )
}

rule preproc_parenthesized_expression { seq("(", _preproc_expression, ")") }

rule preproc_defined {
    choice(
        prec(PREC.CALL, seq("defined", "(", identifier, ")")),
        seq("defined", identifier),
    )
}

rule preproc_unary_expression {
    prec.left(PREC.UNARY, seq(
        field(operator, choice("!", "~", "-", "+")),
        field(argument, _preproc_expression),
    ))
}

rule preproc_call_expression {
    prec(PREC.CALL, seq(
        field(function, identifier),
        field(arguments, alias(preproc_argument_list, argument_list)),
    ))
}

rule preproc_argument_list { seq("(", comma_sep(_preproc_expression), ")") }

rule preproc_binary_expression {
    choice(
        for (op: str, p: int) in [
            ("+", PREC.ADD), ("-", PREC.ADD),
            ("*", PREC.MULTIPLY), ("/", PREC.MULTIPLY), ("%", PREC.MULTIPLY),
            ("||", PREC.LOGICAL_OR), ("&&", PREC.LOGICAL_AND),
            ("|", PREC.INCLUSIVE_OR), ("^", PREC.EXCLUSIVE_OR), ("&", PREC.BITWISE_AND),
            ("==", PREC.EQUAL), ("!=", PREC.EQUAL),
            (">", PREC.RELATIONAL), (">=", PREC.RELATIONAL),
            ("<=", PREC.RELATIONAL), ("<", PREC.RELATIONAL),
            ("<<", PREC.SHIFT), (">>", PREC.SHIFT),
        ] {
            prec.left(p, seq(
                field(left, _preproc_expression),
                field(operator, op),
                field(right, _preproc_expression),
            ))
        }
    )
}

// ---------------------------------------------------------------------------
// Main Grammar
// ---------------------------------------------------------------------------

rule function_definition {
    seq(optional(ms_call_modifier), _declaration_specifiers,
        optional(ms_call_modifier),
        field(declarator, _declarator), field(body, compound_statement))
}

rule _old_style_function_definition {
    seq(optional(ms_call_modifier), _declaration_specifiers,
        field(declarator, alias(_old_style_function_declarator, function_declarator)),
        repeat1(declaration), field(body, compound_statement))
}

rule declaration {
    seq(_declaration_specifiers,
        comma_sep1(field(declarator, choice(
            seq(optional(ms_call_modifier), _declaration_declarator, optional(gnu_asm_expression)),
            init_declarator))),
        ";")
}

rule type_definition {
    seq(optional("__extension__"), "typedef", _type_definition_type,
        _type_definition_declarators, repeat(attribute_specifier), ";")
}

rule _type_definition_type {
    seq(repeat(type_qualifier), field(type, type_specifier), repeat(type_qualifier))
}

rule _type_definition_declarators { comma_sep1(field(declarator, _type_declarator)) }

rule _declaration_modifiers {
    choice(storage_class_specifier, type_qualifier, attribute_specifier,
           attribute_declaration, ms_declspec_modifier)
}

rule _declaration_specifiers {
    prec.right(0, seq(repeat(_declaration_modifiers), field(type, type_specifier),
                   repeat(_declaration_modifiers)))
}

rule linkage_specification {
    seq("extern", field(value, string_literal),
        field(body, choice(function_definition, declaration, declaration_list)))
}

rule attribute_specifier { seq(choice("__attribute__", "__attribute"), "(", argument_list, ")") }

rule attribute {
    seq(optional(seq(field(prefix, identifier), "::")),
        field(name, identifier), optional(argument_list))
}

rule attribute_declaration { seq("[[", comma_sep1(attribute), "]]") }

rule ms_declspec_modifier { seq("__declspec", "(", identifier, ")") }
rule ms_based_modifier { seq("__based", argument_list) }
rule ms_call_modifier { choice("__cdecl", "__clrcall", "__stdcall", "__fastcall", "__thiscall", "__vectorcall") }
rule ms_restrict_modifier { "__restrict" }
rule ms_unsigned_ptr_modifier { "__uptr" }
rule ms_signed_ptr_modifier { "__sptr" }
rule ms_unaligned_ptr_modifier { choice("_unaligned", "__unaligned") }
rule ms_pointer_modifier { choice(ms_unaligned_ptr_modifier, ms_restrict_modifier, ms_unsigned_ptr_modifier, ms_signed_ptr_modifier) }

rule declaration_list { seq("{", repeat(_block_item), "}") }

rule _declarator { choice(attributed_declarator, pointer_declarator, function_declarator, array_declarator, parenthesized_declarator, identifier) }
rule _declaration_declarator { choice(attributed_declarator, pointer_declarator, alias(_function_declaration_declarator, function_declarator), array_declarator, parenthesized_declarator, identifier) }

rule _field_declarator {
    choice(
        alias(attributed_field_declarator, attributed_declarator),
        alias(pointer_field_declarator, pointer_declarator),
        alias(function_field_declarator, function_declarator),
        alias(array_field_declarator, array_declarator),
        alias(parenthesized_field_declarator, parenthesized_declarator),
        _field_identifier,
    )
}

rule _type_declarator {
    choice(
        alias(attributed_type_declarator, attributed_declarator),
        alias(pointer_type_declarator, pointer_declarator),
        alias(function_type_declarator, function_declarator),
        alias(array_type_declarator, array_declarator),
        alias(parenthesized_type_declarator, parenthesized_declarator),
        _type_identifier,
        alias(choice("signed", "unsigned", "long", "short"), primitive_type),
        primitive_type,
    )
}

rule _abstract_declarator {
    choice(abstract_pointer_declarator, abstract_function_declarator,
           abstract_array_declarator, abstract_parenthesized_declarator)
}

rule parenthesized_declarator { prec.dynamic(PREC.PAREN_DECLARATOR, seq("(", optional(ms_call_modifier), _declarator, ")")) }
rule parenthesized_field_declarator { prec.dynamic(PREC.PAREN_DECLARATOR, seq("(", optional(ms_call_modifier), _field_declarator, ")")) }
rule parenthesized_type_declarator { prec.dynamic(PREC.PAREN_DECLARATOR, seq("(", optional(ms_call_modifier), _type_declarator, ")")) }
rule abstract_parenthesized_declarator { prec(1, seq("(", optional(ms_call_modifier), _abstract_declarator, ")")) }

rule attributed_declarator { prec.right(0, seq(_declarator, repeat1(attribute_declaration))) }
rule attributed_field_declarator { prec.right(0, seq(_field_declarator, repeat1(attribute_declaration))) }
rule attributed_type_declarator { prec.right(0, seq(_type_declarator, repeat1(attribute_declaration))) }

rule pointer_declarator { prec.dynamic(1, prec.right(0, seq(optional(ms_based_modifier), "*", repeat(ms_pointer_modifier), repeat(type_qualifier), field(declarator, _declarator)))) }
rule pointer_field_declarator { prec.dynamic(1, prec.right(0, seq(optional(ms_based_modifier), "*", repeat(ms_pointer_modifier), repeat(type_qualifier), field(declarator, _field_declarator)))) }
rule pointer_type_declarator { prec.dynamic(1, prec.right(0, seq(optional(ms_based_modifier), "*", repeat(ms_pointer_modifier), repeat(type_qualifier), field(declarator, _type_declarator)))) }
rule abstract_pointer_declarator { prec.dynamic(1, prec.right(0, seq("*", repeat(ms_pointer_modifier), repeat(type_qualifier), field(declarator, optional(_abstract_declarator))))) }

rule function_declarator {
    prec.right(1, seq(
        field(declarator, _declarator), field(parameters, parameter_list),
        optional(gnu_asm_expression),
        repeat(choice(attribute_specifier, identifier, alias(preproc_call_expression, call_expression)))))
}

rule _function_declaration_declarator {
    prec.right(1, seq(
        field(declarator, _declarator), field(parameters, parameter_list),
        optional(gnu_asm_expression), repeat(attribute_specifier)))
}

rule function_field_declarator { prec(1, seq(field(declarator, _field_declarator), field(parameters, parameter_list))) }
rule function_type_declarator { prec(1, seq(field(declarator, _type_declarator), field(parameters, parameter_list))) }
rule abstract_function_declarator { prec(1, seq(field(declarator, optional(_abstract_declarator)), field(parameters, parameter_list))) }

rule _old_style_function_declarator {
    seq(field(declarator, _declarator),
        field(parameters, alias(_old_style_parameter_list, parameter_list)))
}

rule array_declarator { prec(1, seq(field(declarator, _declarator), "[", repeat(choice(type_qualifier, "static")), field(size, optional(choice(expression, "*"))), "]")) }
rule array_field_declarator { prec(1, seq(field(declarator, _field_declarator), "[", repeat(choice(type_qualifier, "static")), field(size, optional(choice(expression, "*"))), "]")) }
rule array_type_declarator { prec(1, seq(field(declarator, _type_declarator), "[", repeat(choice(type_qualifier, "static")), field(size, optional(choice(expression, "*"))), "]")) }
rule abstract_array_declarator { prec(1, seq(field(declarator, optional(_abstract_declarator)), "[", repeat(choice(type_qualifier, "static")), field(size, optional(choice(expression, "*"))), "]")) }

rule init_declarator { seq(field(declarator, _declarator), "=", field(value, choice(initializer_list, expression))) }

rule compound_statement { seq("{", repeat(_block_item), "}") }

rule storage_class_specifier {
    choice("extern", "static", "auto", "register", "inline",
           "__inline", "__inline__", "__forceinline", "thread_local", "__thread")
}

rule type_qualifier {
    choice("const", "constexpr", "volatile", "restrict", "__restrict__",
           "__extension__", "_Atomic", "_Noreturn", "noreturn", "_Nonnull",
           alignas_qualifier)
}

rule alignas_qualifier { seq(choice("alignas", "_Alignas"), "(", choice(expression, type_descriptor), ")") }

rule type_specifier {
    choice(struct_specifier, union_specifier, enum_specifier,
           macro_type_specifier, sized_type_specifier, primitive_type, _type_identifier)
}

rule sized_type_specifier {
    choice(
        seq(repeat(choice("signed", "unsigned", "long", "short")),
            field(type, optional(choice(prec.dynamic(-1, _type_identifier), primitive_type))),
            repeat1(choice("signed", "unsigned", "long", "short"))),
        seq(repeat1(choice("signed", "unsigned", "long", "short")),
            repeat(type_qualifier),
            field(type, optional(choice(prec.dynamic(-1, _type_identifier), primitive_type))),
            repeat(choice("signed", "unsigned", "long", "short"))),
    )
}

rule primitive_type {
    token(choice(
        "bool", "char", "int", "float", "double", "void",
        "size_t", "ssize_t", "ptrdiff_t", "intptr_t", "uintptr_t",
        "charptr_t", "nullptr_t", "max_align_t",
        "int8_t", "int16_t", "int32_t", "int64_t",
        "uint8_t", "uint16_t", "uint32_t", "uint64_t",
        "char8_t", "char16_t", "char32_t", "char64_t",
    ))
}

rule enum_specifier {
    seq("enum", choice(
        seq(field(name, _type_identifier),
            optional(seq(":", field(underlying_type, primitive_type))),
            field(body, optional(enumerator_list))),
        field(body, enumerator_list)),
    optional(attribute_specifier))
}

rule enumerator_list {
    seq("{",
        repeat(choice(
            seq(enumerator, ","),
            alias(preproc_if_in_enumerator_list, preproc_if),
            alias(preproc_ifdef_in_enumerator_list, preproc_ifdef),
            seq(preproc_call, ","))),
        optional(seq(choice(
            enumerator,
            alias(preproc_if_in_enumerator_list_no_comma, preproc_if),
            alias(preproc_ifdef_in_enumerator_list_no_comma, preproc_ifdef),
            preproc_call))),
        "}")
}

rule struct_specifier {
    prec.right(0, seq("struct", optional(attribute_specifier), optional(ms_declspec_modifier),
        choice(seq(field(name, _type_identifier), field(body, optional(field_declaration_list))),
               field(body, field_declaration_list)),
        optional(attribute_specifier)))
}

rule union_specifier {
    prec.right(0, seq("union", optional(ms_declspec_modifier),
        choice(seq(field(name, _type_identifier), field(body, optional(field_declaration_list))),
               field(body, field_declaration_list)),
        optional(attribute_specifier)))
}

rule field_declaration_list { seq("{", repeat(_field_declaration_list_item), "}") }

rule _field_declaration_list_item {
    choice(field_declaration, preproc_def, preproc_function_def, preproc_call,
           alias(preproc_if_in_field_declaration_list, preproc_if),
           alias(preproc_ifdef_in_field_declaration_list, preproc_ifdef))
}

rule field_declaration {
    seq(_declaration_specifiers, optional(_field_declaration_declarator),
        optional(attribute_specifier), ";")
}

rule _field_declaration_declarator {
    comma_sep1(seq(field(declarator, _field_declarator), optional(bitfield_clause)))
}

rule bitfield_clause { seq(":", expression) }

rule enumerator { seq(field(name, identifier), optional(seq("=", field(value, expression)))) }

rule variadic_parameter { "..." }

rule parameter_list {
    seq("(", choice(comma_sep(choice(parameter_declaration, variadic_parameter)), compound_statement), ")")
}

rule _old_style_parameter_list { seq("(", comma_sep(choice(identifier, variadic_parameter)), ")") }

rule parameter_declaration {
    seq(_declaration_specifiers,
        optional(field(declarator, choice(_declarator, _abstract_declarator))),
        repeat(attribute_specifier))
}

// ---------------------------------------------------------------------------
// Statements
// ---------------------------------------------------------------------------

rule attributed_statement { seq(repeat1(attribute_declaration), statement) }
rule statement { choice(case_statement, _non_case_statement) }

rule _non_case_statement {
    choice(attributed_statement, labeled_statement, compound_statement,
           expression_statement, if_statement, switch_statement,
           do_statement, while_statement, for_statement,
           return_statement, break_statement, continue_statement,
           goto_statement, seh_try_statement, seh_leave_statement)
}

rule _top_level_statement {
    choice(case_statement, attributed_statement, labeled_statement, compound_statement,
           alias(_top_level_expression_statement, expression_statement),
           if_statement, switch_statement, do_statement, while_statement,
           for_statement, return_statement, break_statement,
           continue_statement, goto_statement)
}

rule labeled_statement { seq(field(label, _statement_identifier), ":", choice(declaration, statement)) }

rule _top_level_expression_statement { seq(optional(_expression_not_binary), ";") }
rule expression_statement { seq(optional(choice(expression, comma_expression)), ";") }

rule if_statement {
    prec.right(0, seq("if", field(condition, parenthesized_expression),
        field(consequence, statement), optional(field(alternative, else_clause))))
}

rule else_clause { seq("else", statement) }

rule switch_statement { seq("switch", field(condition, parenthesized_expression), field(body, compound_statement)) }

rule case_statement {
    prec.right(0, seq(
        choice(seq("case", field(value, expression)), "default"), ":",
        repeat(choice(_non_case_statement, declaration, type_definition))))
}

rule while_statement { seq("while", field(condition, parenthesized_expression), field(body, statement)) }
rule do_statement { seq("do", field(body, statement), "while", field(condition, parenthesized_expression), ";") }

rule for_statement { seq("for", "(", _for_statement_body, ")", field(body, statement)) }
rule _for_statement_body {
    seq(choice(field(initializer, declaration),
               seq(field(initializer, optional(choice(expression, comma_expression))), ";")),
        field(condition, optional(choice(expression, comma_expression))), ";",
        field(update, optional(choice(expression, comma_expression))))
}

rule return_statement { seq("return", optional(choice(expression, comma_expression)), ";") }
rule break_statement { seq("break", ";") }
rule continue_statement { seq("continue", ";") }
rule goto_statement { seq("goto", field(label, _statement_identifier), ";") }

rule seh_try_statement { seq("__try", field(body, compound_statement), choice(seh_except_clause, seh_finally_clause)) }
rule seh_except_clause { seq("__except", field(filter, parenthesized_expression), field(body, compound_statement)) }
rule seh_finally_clause { seq("__finally", field(body, compound_statement)) }
rule seh_leave_statement { seq("__leave", ";") }

// ---------------------------------------------------------------------------
// Expressions
// ---------------------------------------------------------------------------

rule expression { choice(_expression_not_binary, binary_expression) }

rule _expression_not_binary {
    choice(conditional_expression, assignment_expression,
           unary_expression, update_expression, cast_expression,
           pointer_expression, sizeof_expression, alignof_expression,
           offsetof_expression, generic_expression,
           subscript_expression, call_expression, field_expression,
           compound_literal_expression, identifier, number_literal,
           _string, true, false, null, char_literal,
           parenthesized_expression, gnu_asm_expression, extension_expression)
}

rule _string { prec.left(0, choice(string_literal, concatenated_string)) }

rule comma_expression { seq(field(left, expression), ",", field(right, choice(expression, comma_expression))) }

rule conditional_expression {
    prec.right(PREC.CONDITIONAL, seq(
        field(condition, expression), "?",
        optional(field(consequence, choice(expression, comma_expression))),
        ":", field(alternative, expression)))
}

rule _assignment_left_expression {
    choice(identifier, call_expression, field_expression,
           pointer_expression, subscript_expression, parenthesized_expression)
}

rule assignment_expression {
    prec.right(PREC.ASSIGNMENT, seq(
        field(left, _assignment_left_expression),
        field(operator, choice("=", "*=", "/=", "%=", "+=", "-=", "<<=", ">>=", "&=", "^=", "|=")),
        field(right, expression)))
}

rule pointer_expression { prec.left(PREC.CAST, seq(field(operator, choice("*", "&")), field(argument, expression))) }
rule unary_expression { prec.left(PREC.UNARY, seq(field(operator, choice("!", "~", "-", "+")), field(argument, expression))) }

rule binary_expression {
    choice(
        for (op: str, p: int) in [
            ("+", PREC.ADD), ("-", PREC.ADD),
            ("*", PREC.MULTIPLY), ("/", PREC.MULTIPLY), ("%", PREC.MULTIPLY),
            ("||", PREC.LOGICAL_OR), ("&&", PREC.LOGICAL_AND),
            ("|", PREC.INCLUSIVE_OR), ("^", PREC.EXCLUSIVE_OR), ("&", PREC.BITWISE_AND),
            ("==", PREC.EQUAL), ("!=", PREC.EQUAL),
            (">", PREC.RELATIONAL), (">=", PREC.RELATIONAL),
            ("<=", PREC.RELATIONAL), ("<", PREC.RELATIONAL),
            ("<<", PREC.SHIFT), (">>", PREC.SHIFT),
        ] {
            prec.left(p, seq(field(left, expression), field(operator, op), field(right, expression)))
        }
    )
}

rule update_expression {
    prec.right(PREC.UNARY, choice(
        seq(field(operator, choice("--", "++")), field(argument, expression)),
        seq(field(argument, expression), field(operator, choice("--", "++")))))
}

rule cast_expression { prec(PREC.CAST, seq("(", field(type, type_descriptor), ")", field(value, expression))) }

rule type_descriptor {
    seq(repeat(type_qualifier), field(type, type_specifier),
        repeat(type_qualifier), field(declarator, optional(_abstract_declarator)))
}

rule sizeof_expression {
    prec(PREC.SIZEOF, seq("sizeof", choice(
        field(value, expression), seq("(", field(type, type_descriptor), ")"))))
}

rule alignof_expression {
    prec(PREC.SIZEOF, seq(
        choice("__alignof__", "__alignof", "_alignof", "alignof", "_Alignof"),
        seq("(", field(type, type_descriptor), ")")))
}

rule offsetof_expression {
    prec(PREC.OFFSETOF, seq("offsetof",
        seq("(", field(type, type_descriptor), ",", field(member, _field_identifier), ")")))
}

rule generic_expression {
    prec(PREC.CALL, seq("_Generic", "(", expression, ",",
        comma_sep1(seq(type_descriptor, ":", expression)), ")"))
}

rule subscript_expression { prec(PREC.SUBSCRIPT, seq(field(argument, expression), "[", field(index, expression), "]")) }
rule call_expression { prec(PREC.CALL, seq(field(function, expression), field(arguments, argument_list))) }

rule gnu_asm_expression {
    prec(PREC.CALL, seq(
        choice("asm", "__asm__", "__asm"), repeat(gnu_asm_qualifier),
        "(", field(assembly_code, _string),
        optional(seq(
            field(output_operands, gnu_asm_output_operand_list),
            optional(seq(
                field(input_operands, gnu_asm_input_operand_list),
                optional(seq(
                    field(clobbers, gnu_asm_clobber_list),
                    optional(field(goto_labels, gnu_asm_goto_list)))))))),
        ")"))
}

rule gnu_asm_qualifier { choice("volatile", "__volatile__", "inline", "goto") }
rule gnu_asm_output_operand_list { seq(":", comma_sep(field(operand, gnu_asm_output_operand))) }
rule gnu_asm_output_operand { seq(optional(seq("[", field(symbol, identifier), "]")), field(constraint, string_literal), "(", field(value, expression), ")") }
rule gnu_asm_input_operand_list { seq(":", comma_sep(field(operand, gnu_asm_input_operand))) }
rule gnu_asm_input_operand { seq(optional(seq("[", field(symbol, identifier), "]")), field(constraint, string_literal), "(", field(value, expression), ")") }
rule gnu_asm_clobber_list { seq(":", comma_sep(field(register, _string))) }
rule gnu_asm_goto_list { seq(":", comma_sep(field(label, identifier))) }

rule extension_expression { seq("__extension__", expression) }

rule argument_list { seq("(", comma_sep(choice(expression, compound_statement)), ")") }

rule field_expression {
    seq(prec(PREC.FIELD, seq(field(argument, expression), field(operator, choice(".", "->")))),
        field(field, _field_identifier))
}

rule compound_literal_expression { seq("(", field(type, type_descriptor), ")", field(value, initializer_list)) }
rule parenthesized_expression { seq("(", choice(expression, comma_expression, compound_statement), ")") }

rule initializer_list { seq("{", comma_sep(choice(initializer_pair, expression, initializer_list)), optional(","), "}") }

rule initializer_pair {
    choice(
        seq(field(designator, repeat1(choice(subscript_designator, field_designator, subscript_range_designator))),
            "=", field(value, choice(expression, initializer_list))),
        seq(field(designator, _field_identifier), ":", field(value, choice(expression, initializer_list))))
}

rule subscript_designator { seq("[", expression, "]") }
rule subscript_range_designator { seq("[", field(start, expression), "...", field(end, expression), "]") }
rule field_designator { seq(".", _field_identifier) }

// ---------------------------------------------------------------------------
// Literals
// ---------------------------------------------------------------------------

// decimalDigits = seq(repeat1(/[0-9]/), repeat(seq("'", repeat1(/[0-9]/))))
// hexDigits = seq(repeat1(/[0-9a-fA-F]/), repeat(seq("'", repeat1(/[0-9a-fA-F]/))))
rule number_literal {
    token(seq(
        optional(regex(r"[-\+]")),
        optional(choice(regex("0[xX]"), regex("0[bB]"))),
        choice(
            seq(
                choice(
                    seq(repeat1(regex("[0-9]")), repeat(seq("'", repeat1(regex("[0-9]"))))),
                    seq(regex("0[bB]"), seq(repeat1(regex("[0-9]")), repeat(seq("'", repeat1(regex("[0-9]")))))),
                    seq(regex("0[xX]"), seq(repeat1(regex("[0-9a-fA-F]")), repeat(seq("'", repeat1(regex("[0-9a-fA-F]")))))),
                ),
                optional(seq(".", optional(seq(repeat1(regex("[0-9a-fA-F]")), repeat(seq("'", repeat1(regex("[0-9a-fA-F]")))))))),
            ),
            seq(".", seq(repeat1(regex("[0-9]")), repeat(seq("'", repeat1(regex("[0-9]")))))),
        ),
        optional(seq(
            regex("[eEpP]"),
            optional(seq(
                optional(regex(r"[-\+]")),
                seq(repeat1(regex("[0-9a-fA-F]")), repeat(seq("'", repeat1(regex("[0-9a-fA-F]"))))),
            )),
        )),
        regex("[uUlLwWfFbBdD]*"),
    ))
}

rule char_literal {
    seq(choice("L'", "u'", "U'", "u8'", "'"),
        repeat1(choice(escape_sequence, alias(token.immediate(regex(r"[^\n']")), character))),
        "'")
}

rule concatenated_string {
    prec.right(0, seq(
        choice(seq(identifier, string_literal), seq(string_literal, string_literal), seq(string_literal, identifier)),
        repeat(choice(string_literal, identifier))))
}

rule string_literal {
    seq(choice("L\"", "u\"", "U\"", "u8\"", "\""),
        repeat(choice(alias(token.immediate(prec(1, regex(r#"[^\\"\n]+"#))), string_content), escape_sequence)),
        "\"")
}

rule escape_sequence {
    token(prec(1, seq("\\", choice(regex("[^xuU]"), regex(r"\d{2,3}"), regex("x[0-9a-fA-F]{1,4}"), regex("u[0-9a-fA-F]{4}"), regex("U[0-9a-fA-F]{8}")))))
}

rule system_lib_string { token(seq("<", repeat(choice(regex(r"[^>\n]"), "\\>")), ">")) }

rule true { token(choice("TRUE", "true")) }
rule false { token(choice("FALSE", "false")) }
rule null { choice("NULL", "nullptr") }

rule identifier { regex(r"(\p{XID_Start}|\$|_|\\u[0-9A-Fa-f]{4}|\\U[0-9A-Fa-f]{8})(\p{XID_Continue}|\$|\\u[0-9A-Fa-f]{4}|\\U[0-9A-Fa-f]{8})*") }

rule _type_identifier { alias(identifier, type_identifier) }
rule _field_identifier { alias(identifier, field_identifier) }
rule _statement_identifier { alias(identifier, statement_identifier) }

rule _empty_declaration { seq(type_specifier, ";") }

rule macro_type_specifier {
    prec.dynamic(-1, seq(field(name, identifier), "(", field(type, type_descriptor), ")"))
}

rule comment {
    token(choice(
        seq("//", regex(r"(\\+(.|\r?\n)|[^\\\n])*")),
        seq("/*", regex(r"[^*]*\*+([^/*][^*]*\*+)*"), "/")))
}
