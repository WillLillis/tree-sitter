// Test helper module for import tests

macro comma_sep1(item: rule_t) rule_t =
    seq(item, repeat(seq(",", item)))

macro comma_sep(item: rule_t) rule_t =
    optional(comma_sep1(item))

macro sep_by(separator: str_t, item: rule_t) rule_t =
    seq(item, repeat(seq(separator, item)))

let PREC = { ADD: 1, MUL: 2 }

let GREETING = "hello"
